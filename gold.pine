//@version=6
strategy("RSI PRO Auto TP/SL | tradewsamet", shorttitle="RSI Pro Strategy", overlay=false,
     initial_capital=50000, default_qty_type=strategy.fixed, default_qty_value=1,
     calc_on_every_tick=false, pyramiding=0)

//══════════════════════════════════════════════════════════════════════════════
// INPUTS
//══════════════════════════════════════════════════════════════════════════════
groupCore = "RSI Engine"
rsiSource  = input.source(close, "RSI Source", group=groupCore)
rsiLength  = input.int(14, "RSI Length", minval=1, group=groupCore)
smoothMode = input.string("EMA", "RSI Smoothing", options=["None", "EMA", "SMA", "RMA"], group=groupCore)
smoothLen  = input.int(5, "Smoothing Length", minval=1, group=groupCore)
signalLen  = input.int(9, "Signal Length", minval=1, group=groupCore)
signalMode = input.string("EMA", "Signal Smoothing", options=["EMA", "SMA", "RMA"], group=groupCore)

groupZones = "Zones"
overbought = input.int(70, "Overbought", minval=50, maxval=100, group=groupZones)
oversold   = input.int(30, "Oversold", minval=0, maxval=50, group=groupZones)
extremeHigh = input.int(80, "Extreme High", minval=60, maxval=100, group=groupZones)
extremeLow  = input.int(20, "Extreme Low", minval=0, maxval=40, group=groupZones)

groupStrat = "Strategy Rules"
entry_rsi_threshold  = input.int(36,  "Enter Long if RSI Below", minval=1,  maxval=49,  group=groupStrat)
tp_rsi_level         = input.int(60,  "Take Profit RSI Level",   minval=51, maxval=100, group=groupStrat)
trailing_rsi_drop    = input.int(10,  "Trailing Stop (RSI Drop)", minval=1,  maxval=30,  group=groupStrat)

groupVisual = "Visuals"
showBgExtreme = input.bool(true, "Highlight Extreme Background", group=groupVisual)
showPanel     = input.bool(true, "Show Status Panel", group=groupVisual)
panelPosition = input.string("Top Right", "Panel Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=groupVisual)
panelTextSize = input.string("Small", "Panel Text Size", options=["Tiny", "Small", "Normal"], group=groupVisual)

//══════════════════════════════════════════════════════════════════════════════
// COLORS
//══════════════════════════════════════════════════════════════════════════════
clrBg       = color.rgb(13, 17, 23)
clrHeader   = color.rgb(31, 41, 55)
clrBorder   = color.rgb(48, 54, 61)
clrText     = color.rgb(230, 237, 243)
clrMuted    = color.rgb(139, 148, 158)
clrBlue     = color.rgb(88, 166, 255)
clrGreen    = color.rgb(34, 197, 94)
clrRed      = color.rgb(239, 68, 68)
clrCardA    = color.rgb(22, 27, 34)
clrCardB    = color.rgb(18, 22, 28)

//══════════════════════════════════════════════════════════════════════════════
// HELPERS
//══════════════════════════════════════════════════════════════════════════════
getTablePosition(_pos) =>
    switch _pos
        "Top Left"     => position.top_left
        "Bottom Right" => position.bottom_right
        "Bottom Left"  => position.bottom_left
        => position.top_right

getTableTextSize(_sz) =>
    switch _sz
        "Tiny"   => size.tiny
        "Normal" => size.normal
        => size.small

ma(_src, _len, _mode) =>
    _mode == "EMA" ? ta.ema(_src, _len) :
     _mode == "SMA" ? ta.sma(_src, _len) :
     _mode == "RMA" ? ta.rma(_src, _len) :
     _src

//══════════════════════════════════════════════════════════════════════════════
// RSI ENGINE
//══════════════════════════════════════════════════════════════════════════════
rsiRaw    = ta.rsi(rsiSource, rsiLength)
rsiSmooth = smoothMode == "None" ? rsiRaw : ma(rsiRaw, smoothLen, smoothMode)
signal    = ma(rsiSmooth, signalLen, signalMode)
spread    = rsiSmooth - signal
delta     = rsiSmooth - rsiSmooth[1]

isExtremeHigh = rsiSmooth >= extremeHigh
isOverbought  = rsiSmooth >= overbought
isBullish     = rsiSmooth > 50 and rsiSmooth < overbought
isNeutral     = rsiSmooth >= 45 and rsiSmooth <= 55
isBearish     = rsiSmooth < 50 and rsiSmooth > oversold
isOversold    = rsiSmooth <= oversold
isExtremeLow  = rsiSmooth <= extremeLow

rsiColor = isExtremeHigh ? clrRed : isExtremeLow ? clrGreen : clrBlue

//══════════════════════════════════════════════════════════════════════════════
// LEVELS
//══════════════════════════════════════════════════════════════════════════════
h100 = hline(100, "100", color=color.new(clrMuted, 100))
h0   = hline(0,   "0",   color=color.new(clrMuted, 100))
h50  = hline(50,  "Center", color=color.new(clrMuted, 60), linestyle=hline.style_dotted)
hOB  = hline(overbought, "Overbought", color=color.new(clrRed, 30),   linestyle=hline.style_dashed)
hOS  = hline(oversold,   "Oversold",   color=color.new(clrGreen, 30), linestyle=hline.style_dashed)
hEH  = hline(extremeHigh, "Extreme High", color=color.new(clrRed, 55),   linestyle=hline.style_dotted)
hEL  = hline(extremeLow,  "Extreme Low",  color=color.new(clrGreen, 55), linestyle=hline.style_dotted)

// Entry and TP threshold lines
hEntry = hline(entry_rsi_threshold, "Entry Threshold", color=color.new(clrGreen, 20), linestyle=hline.style_solid)
hTP    = hline(tp_rsi_level,        "TP Level",        color=color.new(clrBlue, 20),  linestyle=hline.style_solid)

fill(hOB, h100, color=color.new(clrRed,   70), title="Overbought Zone")
fill(hOS, h0,   color=color.new(clrGreen, 70), title="Oversold Zone")

bgcolor(showBgExtreme and isExtremeHigh ? color.new(clrRed,   80) : na)
bgcolor(showBgExtreme and isExtremeLow  ? color.new(clrGreen, 80) : na)

//══════════════════════════════════════════════════════════════════════════════
// RSI PLOTS
//══════════════════════════════════════════════════════════════════════════════
plot(rsiSmooth, "RSI",    color=rsiColor,               linewidth=3)
plot(signal,    "Signal", color=color.new(clrMuted, 30), linewidth=1)

//══════════════════════════════════════════════════════════════════════════════
// STRATEGY LOGIC
// Entry:  RSI drops below entry_rsi_threshold (default 36)
// Exit 1: RSI climbs to tp_rsi_level (default 60)
// Exit 2: RSI drops more than trailing_rsi_drop pts from highest RSI since entry
//══════════════════════════════════════════════════════════════════════════════
var float highest_rsi_since_entry = na
var bool  in_trade = false

// Track highest RSI since entry for trailing stop
if strategy.position_size > 0
    if na(highest_rsi_since_entry)
        highest_rsi_since_entry := rsiSmooth
    else
        highest_rsi_since_entry := math.max(highest_rsi_since_entry, rsiSmooth)
else
    highest_rsi_since_entry := na

// Entry condition: RSI crosses below threshold on confirmed bar
entry_condition = ta.crossunder(rsiSmooth, entry_rsi_threshold) and barstate.isconfirmed

// Exit conditions
tp_condition       = strategy.position_size > 0 and rsiSmooth >= tp_rsi_level
trailing_condition = strategy.position_size > 0 and not na(highest_rsi_since_entry) and rsiSmooth <= highest_rsi_since_entry - trailing_rsi_drop

// Execute
if entry_condition and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    alert("RSI Entry | RSI crossed below " + str.tostring(entry_rsi_threshold), alert.freq_once_per_bar_close)

if tp_condition
    strategy.close("Long", comment="TP Hit RSI " + str.tostring(tp_rsi_level))
    alert("RSI TP Hit | RSI reached " + str.tostring(tp_rsi_level), alert.freq_once_per_bar_close)

if trailing_condition
    strategy.close("Long", comment="Trailing Stop -" + str.tostring(trailing_rsi_drop) + " pts")
    alert("RSI Trailing Stop | RSI dropped " + str.tostring(trailing_rsi_drop) + " pts from high", alert.freq_once_per_bar_close)

// Signal labels on RSI pane
if entry_condition
    label.new(bar_index, rsiSmooth, "ENTRY\n" + str.tostring(math.round(rsiSmooth, 1)),
              style=label.style_label_up, color=color.new(clrGreen, 0),
              textcolor=color.black, size=size.small)

if tp_condition and barstate.isconfirmed
    label.new(bar_index, rsiSmooth, "TP\n" + str.tostring(math.round(rsiSmooth, 1)),
              style=label.style_label_down, color=color.new(clrBlue, 0),
              textcolor=color.white, size=size.small)

if trailing_condition and barstate.isconfirmed
    label.new(bar_index, rsiSmooth, "TRAIL\n" + str.tostring(math.round(rsiSmooth, 1)),
              style=label.style_label_down, color=color.new(clrRed, 0),
              textcolor=color.white, size=size.small)

//══════════════════════════════════════════════════════════════════════════════
// STATUS PANEL
//══════════════════════════════════════════════════════════════════════════════
statusText =
     isExtremeHigh ? "Extreme High" :
     isOverbought  ? "Overbought"   :
     isBullish     ? "Bullish"      :
     isNeutral     ? "Neutral"      :
     isBearish     ? "Bearish"      :
     isOversold    ? "Oversold"     :
     "Extreme Low"

statusColor =
     isExtremeHigh ? clrRed   :
     isOverbought  ? clrRed   :
     isBullish     ? clrBlue  :
     isNeutral     ? clrText  :
     isBearish     ? clrBlue  :
     isOversold    ? clrGreen :
     clrGreen

momentumText =
     delta >= 1.5  ? "Strong Up"   :
     delta > 0     ? "Up"          :
     delta <= -1.5 ? "Strong Down" :
     delta < 0     ? "Down"        :
     "Flat"

momentumColor =
     delta >= 1.5  ? clrGreen :
     delta > 0     ? clrBlue  :
     delta <= -1.5 ? clrRed   :
     delta < 0     ? clrRed   :
     clrMuted

tradeStatus      = strategy.position_size > 0 ? "IN TRADE" : "FLAT"
tradeStatusColor = strategy.position_size > 0 ? clrGreen   : clrMuted
rsiHighText      = strategy.position_size > 0 and not na(highest_rsi_since_entry) ? str.tostring(math.round(highest_rsi_since_entry, 1)) : "—"
trailStopText    = strategy.position_size > 0 and not na(highest_rsi_since_entry) ? str.tostring(math.round(highest_rsi_since_entry - trailing_rsi_drop, 1)) : "—"

panelPos  = getTablePosition(panelPosition)
panelSize = getTableTextSize(panelTextSize)

var table panel = table.new(panelPos, 2, 9, border_width=1, frame_color=clrBorder, border_color=clrBorder)

if barstate.islast and showPanel
    table.cell(panel, 0, 0, "RSI STRATEGY",  text_color=clrText,  text_size=panelSize, bgcolor=clrHeader)
    table.cell(panel, 1, 0, "VALUE",          text_color=clrText,  text_size=panelSize, bgcolor=clrHeader)
    table.cell(panel, 0, 1, "RSI",            text_color=clrMuted, text_size=panelSize, bgcolor=clrCardA)
    table.cell(panel, 1, 1, str.tostring(rsiSmooth, "#.##"), text_color=rsiColor, text_size=panelSize, bgcolor=clrCardA)
    table.cell(panel, 0, 2, "Signal",         text_color=clrMuted, text_size=panelSize, bgcolor=clrCardB)
    table.cell(panel, 1, 2, str.tostring(signal, "#.##"),    text_color=clrText,  text_size=panelSize, bgcolor=clrCardB)
    table.cell(panel, 0, 3, "Status",         text_color=clrMuted, text_size=panelSize, bgcolor=clrCardA)
    table.cell(panel, 1, 3, statusText,        text_color=statusColor, text_size=panelSize, bgcolor=clrCardA)
    table.cell(panel, 0, 4, "Momentum",       text_color=clrMuted, text_size=panelSize, bgcolor=clrCardB)
    table.cell(panel, 1, 4, momentumText,      text_color=momentumColor, text_size=panelSize, bgcolor=clrCardB)
    table.cell(panel, 0, 5, "Position",       text_color=clrMuted, text_size=panelSize, bgcolor=clrCardA)
    table.cell(panel, 1, 5, tradeStatus,       text_color=tradeStatusColor, text_size=panelSize, bgcolor=clrCardA)
    table.cell(panel, 0, 6, "RSI High",       text_color=clrMuted, text_size=panelSize, bgcolor=clrCardB)
    table.cell(panel, 1, 6, rsiHighText,       text_color=clrText,  text_size=panelSize, bgcolor=clrCardB)
    table.cell(panel, 0, 7, "Trail Stop",     text_color=clrMuted, text_size=panelSize, bgcolor=clrCardA)
    table.cell(panel, 1, 7, trailStopText,     text_color=clrRed,   text_size=panelSize, bgcolor=clrCardA)
    table.cell(panel, 0, 8, "Entry < RSI",    text_color=clrMuted, text_size=panelSize, bgcolor=clrCardB)
    table.cell(panel, 1, 8, str.tostring(entry_rsi_threshold) + " → TP " + str.tostring(tp_rsi_level), text_color=clrGreen, text_size=panelSize, bgcolor=clrCardB)

//══════════════════════════════════════════════════════════════════════════════
// ALERTS
//══════════════════════════════════════════════════════════════════════════════
alertcondition(entry_condition,    title="RSI Entry Signal",   message="RSI dropped below entry threshold -- consider long entry")
alertcondition(tp_condition,       title="RSI Take Profit",    message="RSI reached TP level -- consider closing long")
alertcondition(trailing_condition, title="RSI Trailing Stop",  message="RSI trailing stop triggered -- consider closing long")
