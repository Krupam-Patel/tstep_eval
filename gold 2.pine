//@version=6
strategy("MGC RSI Simple Strategy", shorttitle="MGC RSI 30/60", overlay=false,
     initial_capital=50000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     pyramiding=0,
     calc_on_every_tick=false,
     process_orders_on_close=true)

//════════════════════════════════════════════
// INPUTS
//════════════════════════════════════════════
groupRSI = "RSI Settings"
rsiSource = input.source(close, "RSI Source", group=groupRSI)
rsiLength = input.int(14, "RSI Length", minval=1, group=groupRSI)
smoothMode = input.string("None", "RSI Smoothing", options=["None", "EMA", "SMA", "RMA"], group=groupRSI)
smoothLen = input.int(5, "Smoothing Length", minval=1, group=groupRSI)

groupTrade = "Trade Rules"
entryLevel = input.int(30, "Enter Long Under RSI", minval=1, maxval=49, group=groupTrade)
tpLevel    = input.int(60, "Take Profit Above RSI", minval=51, maxval=100, group=groupTrade)
useStopLoss = input.bool(true, "Use RSI Stop Loss", group=groupTrade)
slLevel    = input.int(20, "Stop Loss Under RSI", minval=1, maxval=49, group=groupTrade)

useRsiTrail = input.bool(true, "Use RSI Trailing Exit", group=groupTrade)
trailDrop   = input.int(5, "RSI Trailing Drop", minval=1, maxval=30, group=groupTrade)
trailArmMin = input.int(0, "Arm Trail Only After RSI Reaches", minval=0, maxval=100, group=groupTrade)

groupRisk = "MGC Settings"
contracts = input.int(1, "Contracts", minval=1, maxval=10, group=groupRisk)
dollarsPerPoint = input.float(10.0, "Dollars Per Point Per Contract", minval=0.01, step=0.01, group=groupRisk)

groupVisual = "Visuals"
showLabels = input.bool(true, "Show Labels", group=groupVisual)
showDebugPlots = input.bool(true, "Show Debug Plots", group=groupVisual)

//════════════════════════════════════════════
// HELPERS
//════════════════════════════════════════════
ma(_src, _len, _mode) =>
    _mode == "EMA" ? ta.ema(_src, _len) :
     _mode == "SMA" ? ta.sma(_src, _len) :
     _mode == "RMA" ? ta.rma(_src, _len) :
     _src

//════════════════════════════════════════════
// RSI
//════════════════════════════════════════════
rsiRaw = ta.rsi(rsiSource, rsiLength)
rsiVal = smoothMode == "None" ? rsiRaw : ma(rsiRaw, smoothLen, smoothMode)

//════════════════════════════════════════════
// POSITION / TRAILING STATE
//════════════════════════════════════════════
inTrade = strategy.position_size > 0
wasInTrade = strategy.position_size[1] > 0
justEntered = inTrade and not wasInTrade

var float highestRsi = na

if justEntered
    highestRsi := rsiVal
else if inTrade
    highestRsi := na(highestRsi) ? rsiVal : math.max(highestRsi, rsiVal)
else
    highestRsi := na

trailLevel = not na(highestRsi) ? highestRsi - trailDrop : na
trailArmed = inTrade and useRsiTrail and not na(highestRsi) and highestRsi >= trailArmMin

//════════════════════════════════════════════
// ENTRY / EXIT LOGIC
//════════════════════════════════════════════
entryCondition = ta.crossunder(rsiVal, entryLevel) and barstate.isconfirmed and not inTrade
tpCondition = ta.crossover(rsiVal, tpLevel) and barstate.isconfirmed and inTrade
slCondition = useStopLoss and ta.crossunder(rsiVal, slLevel) and barstate.isconfirmed and inTrade
trailCondition = trailArmed and barstate.isconfirmed and rsiVal <= trailLevel

exitReason =
     tpCondition ? "TP" :
     slCondition ? "SL" :
     trailCondition ? "TRAIL" :
     ""

exitCondition = exitReason != ""

//════════════════════════════════════════════
// ORDERS
//════════════════════════════════════════════
if entryCondition
    strategy.entry("Long", strategy.long, qty=contracts)

if exitCondition
    strategy.close("Long", comment=exitReason)

//════════════════════════════════════════════
// P&L FOR MGC
//════════════════════════════════════════════
contractsHeld = math.abs(strategy.position_size)
openPoints = inTrade ? close - strategy.position_avg_price : na
openDollarPnL = inTrade ? openPoints * dollarsPerPoint * contractsHeld : 0.0

//════════════════════════════════════════════
// LABELS
//════════════════════════════════════════════
if showLabels and entryCondition
    label.new(bar_index, rsiVal, "BUY\nRSI " + str.tostring(math.round(rsiVal, 1)),
         style=label.style_label_up,
         color=color.new(color.green, 0),
         textcolor=color.black,
         size=size.small)

if showLabels and tpCondition
    label.new(bar_index, rsiVal, "TP\nRSI " + str.tostring(math.round(rsiVal, 1)),
         style=label.style_label_down,
         color=color.new(color.blue, 0),
         textcolor=color.white,
         size=size.small)

if showLabels and slCondition
    label.new(bar_index, rsiVal, "SL\nRSI " + str.tostring(math.round(rsiVal, 1)),
         style=label.style_label_down,
         color=color.new(color.red, 0),
         textcolor=color.white,
         size=size.small)

if showLabels and trailCondition and not tpCondition and not slCondition
    label.new(bar_index, rsiVal, "TRAIL\nRSI " + str.tostring(math.round(rsiVal, 1)),
         style=label.style_label_down,
         color=color.new(color.orange, 0),
         textcolor=color.black,
         size=size.small)

//════════════════════════════════════════════
// PLOTS
//════════════════════════════════════════════
plot(rsiVal, "RSI", color=color.blue, linewidth=2)
hline(entryLevel, "Entry Level", color=color.orange)
hline(tpLevel, "TP Level", color=color.green)
hline(slLevel, "SL Level", color=color.red)
hline(50, "Midline", color=color.gray, linestyle=hline.style_dotted)

plot(showDebugPlots ? strategy.position_size : na, "Position Size", color=color.yellow, linewidth=2, style=plot.style_stepline)
plot(showDebugPlots and inTrade ? strategy.position_avg_price : na, "Avg Entry Price", color=color.purple, linewidth=2)

//════════════════════════════════════════════
// INFO PANEL
//════════════════════════════════════════════
var table panel = table.new(position.top_right, 2, 8, border_width=1)

if barstate.islast
    table.cell(panel, 0, 0, "Metric", bgcolor=color.rgb(30, 30, 30), text_color=color.white)
    table.cell(panel, 1, 0, "Value",  bgcolor=color.rgb(30, 30, 30), text_color=color.white)

    table.cell(panel, 0, 1, "RSI", text_color=color.white)
    table.cell(panel, 1, 1, str.tostring(rsiVal, "#.##"), text_color=color.white)

    table.cell(panel, 0, 2, "Position", text_color=color.white)
    table.cell(panel, 1, 2, str.tostring(strategy.position_size), text_color=color.white)

    table.cell(panel, 0, 3, "Avg Entry", text_color=color.white)
    table.cell(panel, 1, 3, inTrade ? str.tostring(strategy.position_avg_price, "#.##") : "—", text_color=color.white)

    table.cell(panel, 0, 4, "Highest RSI", text_color=color.white)
    table.cell(panel, 1, 4, inTrade and not na(highestRsi) ? str.tostring(highestRsi, "#.##") : "—", text_color=color.white)

    table.cell(panel, 0, 5, "Trail Level", text_color=color.white)
    table.cell(panel, 1, 5, inTrade and not na(trailLevel) ? str.tostring(trailLevel, "#.##") : "—", text_color=color.white)

    table.cell(panel, 0, 6, "Open $", text_color=color.white)
    table.cell(panel, 1, 6, "$" + str.tostring(openDollarPnL, "#.##"), text_color=openDollarPnL >= 0 ? color.lime : color.red)

    table.cell(panel, 0, 7, "Net Profit", text_color=color.white)
    table.cell(panel, 1, 7, "$" + str.tostring(strategy.netprofit, "#.##"), text_color=strategy.netprofit >= 0 ? color.lime : color.red)
